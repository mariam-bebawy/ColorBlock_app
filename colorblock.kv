#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp

<ColorSwatch@Widget>:
    swatch_rgba: (0.882, 0.882, 0.882, 1)
    canvas.before:
        Color:
            rgba: (0.141, 0.188, 0.188, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8), dp(8), dp(8), dp(8)]
    canvas:
        Color:
            rgba: self.swatch_rgba
        RoundedRectangle:
            pos: (self.x + 3, self.y + 3)
            size: (self.width - 6, self.height - 6)
            radius: [dp(6), dp(6), dp(6), dp(6)]


<ColorBlockScreen>:
    orientation: 'vertical'
    padding: dp(16)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: (0.235, 0.384, 0.396, 1)
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: 'COLOR BLOCK'
        font_size: sp(32)
        bold: True
        color: (0.882, 0.882, 0.882, 1)
        size_hint_y: None
        height: dp(56)
        halign: 'center'
        valign: 'middle'
        text_size: self.size

    # Two-column garment selector
    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(12)

        # ---- LEFT column (garment 1) ----
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(8)

            Button:
                text: 'GALLERY  1'
                size_hint_y: None
                height: dp(56)
                font_size: sp(13)
                bold: True
                background_normal: ''
                background_color: (0.008, 0.576, 0.545, 1)
                on_press: root.open_image(1, 'gallery')

            Button:
                text: 'CAMERA  1'
                size_hint_y: None
                height: dp(56)
                font_size: sp(13)
                bold: True
                background_normal: ''
                background_color: (0.008, 0.576, 0.545, 0.7)
                on_press: root.open_image(1, 'camera')

            ColorSwatch:
                id: swatch1
                swatch_rgba: root.swatch1_rgba

            Label:
                id: hex_label_1
                text: ''
                size_hint_y: None
                height: dp(28)
                font_size: sp(11)
                color: (0.882, 0.882, 0.882, 1)
                halign: 'center'
                text_size: self.size

        # ---- RIGHT column (garment 2) ----
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(8)

            Button:
                text: 'GALLERY  2'
                size_hint_y: None
                height: dp(56)
                font_size: sp(13)
                bold: True
                background_normal: ''
                background_color: (0.008, 0.576, 0.545, 1)
                on_press: root.open_image(2, 'gallery')

            Button:
                text: 'CAMERA  2'
                size_hint_y: None
                height: dp(56)
                font_size: sp(13)
                bold: True
                background_normal: ''
                background_color: (0.008, 0.576, 0.545, 0.7)
                on_press: root.open_image(2, 'camera')

            ColorSwatch:
                id: swatch2
                swatch_rgba: root.swatch2_rgba

            Label:
                id: hex_label_2
                text: ''
                size_hint_y: None
                height: dp(28)
                font_size: sp(11)
                color: (0.882, 0.882, 0.882, 1)
                halign: 'center'
                text_size: self.size

    # Match / Clear button row
    BoxLayout:
        orientation: 'horizontal'
        spacing: dp(8)
        size_hint_y: None
        height: dp(60)

        Button:
            text: 'M  A  T  C  H'
            size_hint_x: 0.85
            font_size: sp(15)
            bold: True
            disabled: root.btn_match_disabled
            background_normal: ''
            background_color: (0.008, 0.576, 0.545, 1) if not self.disabled else (0.3, 0.3, 0.3, 0.6)
            on_press: root.check_match()

        Button:
            text: 'X'
            size_hint_x: 0.15
            font_size: sp(18)
            bold: True
            background_normal: ''
            background_color: (0.992, 0.443, 0.408, 1)
            on_press: root.clear()

    # Match result
    Label:
        text: root.match_text
        font_size: sp(22)
        bold: True
        color: (0.882, 0.882, 0.882, 1)
        size_hint_y: None
        height: dp(56)
        halign: 'center'
        valign: 'middle'
        text_size: self.size
